{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "git push origin master",
            "statusMessage": "Pushing to master..."
          }
        ]
      }
    ]
  }
}
